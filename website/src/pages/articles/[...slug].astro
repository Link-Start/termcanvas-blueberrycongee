---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  absoluteUrl,
  articlePath,
  articlesPath,
  dateLocales,
  siteCopy,
  type Locale,
} from "../../lib/site";

export async function getStaticPaths() {
  const entries = await getCollection(
    "articles",
    ({ data }) => data.draft !== true && data.locale === "zh"
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const locale: Locale = "zh";
const copy = siteCopy[locale].articles;

const formatter = new Intl.DateTimeFormat(dateLocales[locale], {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const dateLabel = formatter.format(entry.data.date);
const canonicalPath = articlePath(locale, entry.id);
const alternatePaths: Partial<Record<Locale, string>> = {
  zh: canonicalPath,
};
const title = `${entry.data.seoTitle ?? entry.data.title} · TermCanvas`;
const cover = entry.data.cover ?? "/hero-canvas.png";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: entry.data.date.toISOString(),
  dateModified: (entry.data.updated ?? entry.data.date).toISOString(),
  inLanguage: "zh-CN",
  image: absoluteUrl(Astro.site, cover),
  mainEntityOfPage: absoluteUrl(Astro.site, canonicalPath),
  author: {
    "@type": "Organization",
    name: "TermCanvas",
  },
  publisher: {
    "@type": "Organization",
    name: "TermCanvas",
    logo: {
      "@type": "ImageObject",
      url: absoluteUrl(Astro.site, "/icon.png"),
    },
  },
};
---

<BaseLayout
  title={title}
  description={entry.data.summary}
  ogImage={cover}
  ogType="article"
  locale={locale}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
  structuredData={structuredData}
>
  <article class="article">
    <header class="article-head container-prose">
      <a class="back" href={articlesPath(locale)}>← {copy.back}</a>
      <div class="meta">
        {entry.data.tag && <span class="tag">{entry.data.tag}</span>}
        <time datetime={entry.data.date.toISOString()}>{dateLabel}</time>
      </div>
      <h1 class="title">{entry.data.title}</h1>
      <p class="summary">{entry.data.summary}</p>
    </header>
    <div class="article-body container-prose prose-article">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding: 4rem 0 6rem;
  }
  .article-head {
    margin-bottom: 3rem;
  }
  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
  }
  .back:hover {
    color: var(--color-accent);
  }
  .meta {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-faint);
  }
  .tag {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .title {
    margin-top: 1rem;
    font-size: clamp(2rem, 3.6vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
  }
  .summary {
    margin-top: 1rem;
    color: var(--color-ink-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }
</style>
